# Supabase（登入與後端）
# 請到 https://supabase.com/dashboard 選擇專案 → Settings → API 取得
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 選填：限制只有此信箱可登入（留空則不限制）
VITE_ALLOWED_EMAIL=your-email@example.com

# 選填：設為 true 時不顯示註冊入口，僅顯示登入（搭配 Supabase 關閉註冊後使用）
VITE_DISABLE_SIGNUP=true
